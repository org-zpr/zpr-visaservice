
[nodes.n0]
key = "none"
provider = [["endpoint.zpr.adapter.cn", "node.zpr.org"]]
zpr_address = "fd5a:5052:90de::1"
interfaces = [ "in1" ]
in1.netaddr = "1.2.3.4:5000"


[visa_service]
dock_node = "n0"

[trusted_services.default]
cert_path = ""

[trusted_services.bas]
api = "validation/2"
client = "AuthService"
#cert_path = "bas-tls.crt"
returns_attributes = [ "orange -> #user.orange", "red -> #user.red", "green -> #user.green", "content -> service.content", "bas_id -> user.bas_id"]
identity_attributes = [ "bas_id" ]
provider = [[ "endpoint.zpr.adapter.cn", "bas.zpr.org" ]]
# Will expect to find two service definitions later:
#    bas-vs and bas-client

#[bootstrap]
#"bas.zpr.org" = "rsa-pub-key.pem"


# There are pre-defiend "protocols":
# zpr-validation2
# zpr-authrsa

[protocols.http]
l4protocol = "TCP"
port = 80

[protocols.ping]
l4protocol = "ICMP6"
icmp_type = "request-response"
icmp_codes = [ 128, 129 ]

[services.database]
protocol = "http"
provider = [[ "user.bas_id", "1233" ]]

[services.pingdb]
protocol = "ping"
provider = [[ "user.bas_id", "1233" ]]

[services.bas-vs]
protocol = "zpr-validation2"
port = 3999


