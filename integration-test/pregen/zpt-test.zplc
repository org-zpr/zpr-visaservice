
[nodes.n0]
provider = [["endpoint.zpr.adapter.cn", "node.zpr.org"]]
zpr_address = "fd5a:5052:90de::1"


[trusted_services.bas]
api = "validation/2"
client = "AuthService"
cert_path = "include/bas-tls.crt"
returns_attributes = [ "tint -> endpoint.tint", "color -> user.color", "bas_id -> user.bas_id", "hard -> #endpoint.hardened" ]
identity_attributes = [ "bas_id" ]
provider = [[ "endpoint.zpr.adapter.cn", "bas.zpr.org" ]]

[bootstrap]
"bas.zpr.org" = "include/rsa-pub-key.pem"



[protocols.http]
l4protocol = "TCP"
port = 80

[protocols.ping]
l4protocol = "ICMP6"
icmp_type = "request-response"
icmp_codes = [128, 129]


[services.database]
protocol = "http"
provider = [[ "user.bas_id", "1233" ]]

[services.signalService]
protocol = "http"
provider = [[ "user.bas_id", "1234" ]]

[services.bas-vs]
protocol = "zpr-validation2"
port = 3999

[services.pingy]
protocol = "ping"
provider = [[ "user.bas_id", "1233" ]]
