[nodes.n0]
key = "none"
provider = [["endpoint.zpr.adapter.cn", "node.zpr.org"]]
zpr_address = "fd5a:5052:90de::1"
interfaces = [ "in1" ]
in1.netaddr = "1.2.3.4:5000"

[visa_service]
dock_node = "n0"

[trusted_services.default]
cert_path = ""

[protocols.http]
l4protocol = "iana.TCP"
l7protocol = "http"
port = 80

[services.NodeWeb]
protocol = "http"
provider = [["endpoint.zpr.adapter.cn", "node.zpr.org"]]
