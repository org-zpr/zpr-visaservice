# -*- mode: toml -*-

[nodes."node.zpr.org"]
key = "DNBguc3HqkzfLys68PWm2CnWSA/IhAIFiHFII9cFrFo="
provider = [ ["endpoint.zpr.adapter.cn", "node.zpr.org"]]
zpr_address = "fd5a:5052:90de::1"
interfaces = ["in1"]
in1.netaddr = "10.0.0.21:5000"

[trusted_services.default] # note that "default" is special
cert_path = "ca-cert.pem"

[visa_service] # Only one visa service support at the moment.
dock_node = "node.zpr.org"
admin_attrs = [ [ "endpoint.zpr.adapter.cn", "admin.zpr.org" ] ]

[protocols.ping]
l4protocol = "iana.ICMP6"
icmp_type = "request-response"
icmp_codes = [ 128, 129 ]

[protocols.http]
l4protocol = "iana.TCP"
l7protocol = "http"
port = 80

[protocols.https]
l4protocol = "iana.TCP"
l7protocol = "https"
port = 443

[services.NextCloud]
protocol = "https"

[services.RfcDB]
protocol = "http"

[services.NextCloudPing]
protocol = "ping"

[services.RfcDBPing]
protocol = "ping"




